{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rippa",
  "version": "1.0.0",
  "identifier": "com.vicemi.rippa",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Rippa",
        "width": 400,
        "height": 500,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon16.png",
      "icons/icon32.png",
      "icons/icon128.png",
      "icons/icon.ico"
    ],
    "resources": [
      "../extension/**/*"
    ],
    "externalBin": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "Rippa - Anime Discord Presence",
    "longDescription": "",
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}