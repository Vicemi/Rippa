{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Rippa",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.vicemi.rippa",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [
        "../extension/**/*"
      ],
      "externalBin": [],
      "copyright": "",
      "category": "Utility",
      "shortDescription": "Rippa - Anime Discord Presence",
      "longDescription": "",
      "deb": {
        "depends": []
      },
      "macOS": {
        "frameworks": [],
        "minimumSystemVersion": "",
        "exceptionDomain": "",
        "signingIdentity": null,
        "entitlements": null
      },
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "wix": null,
        "nsis": {
          "installerIcon": "icons/icon.ico",
          "installMode": "perUser",
          "displayLanguageSelector": false,
          "startMenuFolder": "Rippa",
          "allowDowngrades": false,
          "allowToChangeInstallationDirectory": true,
          "oneClick": false,
          "shortcuts": true
        }
      }
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "title": "Rippa",
        "width": 400,
        "height": 500,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "visible": false,
        "center": true
      }
    ],
    "systemTray": {
      "iconPath": "../tray-icon.png",
      "iconAsTemplate": true
    }
  }
}