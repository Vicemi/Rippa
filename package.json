{
  "name": "rippa",
  "version": "1.0.0",
  "description": "Rippa es una aplicación de escritorio que muestra en tu estado de Discord el anime que estás viendo en animeav1.com, utilizando la API de Rich Presence de Discord.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "Vicemi",
  "license": "ISC",
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "discord-rpc": "^4.0.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.vicemi.rippa",
    "productName": "Rippa",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "tray-icon.png"
    ],
    "extraResources": [
      {
        "from": "src/extension",
        "to": "extension",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/discord-rpc"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Rippa",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": true
    }
  }
}
